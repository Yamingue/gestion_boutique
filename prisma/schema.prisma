generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Authentification ──────────────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  nom       String
  role      Role      @default(VENDEUR)
  factures  Facture[]
  commandes CommandeReappro[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role {
  ADMIN
  VENDEUR
}

// ─── Catalogue ─────────────────────────────────────────────────────────────

model Categorie {
  id       String    @id @default(cuid())
  nom      String    @unique
  produits Produit[]
}

model Produit {
  id                String               @id @default(cuid())
  nom               String
  sku               String               @unique
  categorieId       String
  categorie         Categorie            @relation(fields: [categorieId], references: [id])
  prixUnitaire      Int                  // en FCFA (entier)
  stockActuel       Int                  @default(0)
  seuilAlerte       Int                  @default(10)
  image             String?              // chemin relatif ex: /uploads/produits/xxx.webp
  lignesFacture     LigneFacture[]
  lignesCommande    LigneCommande[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

// ─── Clients ───────────────────────────────────────────────────────────────

model Client {
  id        String    @id @default(cuid())
  nom       String
  telephone String?
  email     String?
  adresse   String?
  factures  Facture[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─── Fournisseurs ──────────────────────────────────────────────────────────

model Fournisseur {
  id        String            @id @default(cuid())
  nom       String
  telephone String?
  email     String?
  adresse   String?
  commandes CommandeReappro[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

// ─── Réapprovisionnement ───────────────────────────────────────────────────

model CommandeReappro {
  id            String               @id @default(cuid())
  numero        String               @unique  // ex: CMD-2026-04-001
  fournisseurId String
  fournisseur   Fournisseur          @relation(fields: [fournisseurId], references: [id])
  createdById   String
  createdBy     User                 @relation(fields: [createdById], references: [id])
  statut        StatutCommande       @default(EN_COURS)
  lignes        LigneCommande[]
  totalHT       Int                  // somme en FCFA
  notes         String?
  receivedAt    DateTime?            // date de réception effective
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

enum StatutCommande {
  EN_COURS
  RECUE
  ANNULEE
}

model LigneCommande {
  id          String          @id @default(cuid())
  commandeId  String
  commande    CommandeReappro @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produitId   String
  produit     Produit         @relation(fields: [produitId], references: [id])
  quantite    Int
  prixUnitaire Int            // prix d'achat (snapshot)
}

// ─── Facturation ───────────────────────────────────────────────────────────

model Facture {
  id        String         @id @default(cuid())
  numero    String         @unique
  clientId  String
  client    Client         @relation(fields: [clientId], references: [id])
  vendeurId String
  vendeur   User           @relation(fields: [vendeurId], references: [id])
  statut    StatutFacture  @default(EN_ATTENTE)
  lignes    LigneFacture[]
  totalTTC  Int
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

enum StatutFacture {
  EN_ATTENTE
  PAYEE
  ANNULEE
}

model LigneFacture {
  id           String  @id @default(cuid())
  factureId    String
  facture      Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)
  produitId    String
  produit      Produit @relation(fields: [produitId], references: [id])
  quantite     Int
  prixUnitaire Int
}

// ─── Séquence de numérotation ──────────────────────────────────────────────

model SequenceFacture {
  annee   Int
  mois    Int
  dernier Int @default(0)

  @@id([annee, mois])
}

model SequenceCommande {
  annee   Int
  mois    Int
  dernier Int @default(0)

  @@id([annee, mois])
}
